# NapCat sender target
QQ_TARGET_TYPE=private
QQ_TARGET_ID=123456789
QQ_MESSAGE_PREFIX=CET6 Daily Flow

# LLM config for article generation.
# generate_cet6_materials.py reads variables in this priority order:
# 1. LLM_API_KEY / LLM_BASE_URL / LLM_MODEL
# 2. DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL
# 3. OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL
# If you use DeepSeek-compatible endpoints, filling the DEEPSEEK_* values below is enough.
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional generic aliases. If you fill these, they take precedence over DEEPSEEK_*.
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# Optional OpenAI-compatible fallback.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# NapCat HTTP API
NAPCAT_API_BASE=http://napcat:3000
NAPCAT_ACCESS_TOKEN=change-this-onebot-token
NAPCAT_SHARED_ROOT=/data/shared/articles
LOCAL_ARTICLE_ROOT=/app/articles

# Sender runtime
CET6_BOT_RUN_MODE=scheduler
CET6_BOT_SEND_TIME=07:30
CET6_BOT_POLL_SECONDS=20
CET6_BOT_STATE_FILE=/app/runtime/qq-push-state.json
CET6_BOT_LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Shanghai

# NapCat WebUI
NAPCAT_WEBUI_TOKEN=change-this-webui-token
NAPCAT_WEBUI_PORT=6099

# Optional host uid/gid for NapCat mounted files
NAPCAT_UID=1000
NAPCAT_GID=1000